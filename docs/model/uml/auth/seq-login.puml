@startuml seq-login
' Context: auth
' SDD: SURF-AUTH-004, SURF-AUTH-007
' Revision: 2026-07-19

title Auth — login (password)

actor Utente
participant "UI" as UI
participant "AuthMachine" as AM
participant "MultiAccountMachine" as MAM
participant "AccountManager" as Mgr
participant "Supabase GoTrue" as GT

Utente -> UI : Accedi (email, password)
UI -> AM : SignInRequested
AM --> UI : AuthOperationStarted

AM -> AM : validate email
alt email non valida
  AM --> UI : ValidationRejected
else email ok
  UI -> MAM : OpenAccountWithPassword
  MAM -> Mgr : sign in + open account
  Mgr -> GT : signInWithPassword
  GT --> Mgr : session
  Mgr -> Mgr : adopt session per account
  Mgr --> MAM : AccountOpened
  MAM --> MAM : AccountFocused
  MAM --> AM : AuthOperationCompleted
  AM --> UI : SessionEstablished\noverlay chiuso
end

@enduml
