@startuml seq-signup
' Context: auth
' SDD: SURF-AUTH-004, SURF-AUTH-006, SURF-AUTH-008
' Revision: 2026-07-19

title Auth — registrazione

actor Utente
participant "UI" as UI
participant "AuthMachine" as AM
participant "MultiAccountMachine" as MAM
participant "AccountManager" as Mgr
participant "Supabase GoTrue" as GT

Utente -> UI : Registrati
UI -> AM : SignUpRequested
AM --> UI : AuthOperationStarted

AM -> AM : validate email, username, displayName
alt validazione fallita
  AM --> UI : ValidationRejected
else validazione ok
  UI -> Mgr : isUsernameAvailable
  alt username occupato
    AM --> UI : AuthOperationFailed
  else username libero
    UI -> MAM : OpenAccountWithSignUp
    MAM -> Mgr : sign up + open account
    Mgr -> GT : signUp
    alt email non confermata
      GT --> Mgr : no session
      AM --> UI : AuthOperationFailed\n(conferma email)
    else session ok
      Mgr -> Mgr : adopt session per account
      Mgr --> MAM : AccountOpened
      MAM --> MAM : AccountFocused
      AM --> UI : SessionEstablished
    end
  end
end

@enduml
