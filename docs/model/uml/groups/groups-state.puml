@startuml groups-state
' Context: groups
' SDD: SYS-GROUP, SYS-DELIVERY (erogazione)
' Revision: 2026-07-19

title Groups — GroupHomeMachine + GroupMessagesMachine

state "GroupHomeMachine" as GH {
  state GH_Loading
  state GH_Ready
  state GH_Error

  [*] --> GH_Loading : LoadGroupHome
  GH_Loading --> GH_Ready : GroupHomeLoaded
  GH_Loading --> GH_Error : GroupHomeLoadFailed
  GH_Error --> GH_Loading : LoadGroupHome
  GH_Ready --> GH_Loading : LoadGroupHome
}

state "GroupMessagesMachine" as GM {
  state GM_Loading
  state GM_Ready
  state GM_Sending
  state GM_Error

  [*] --> GM_Loading : InitGroupMessages\nLoadGroupMessages

  GM_Loading --> GM_Ready : GroupMessagesLoaded
  GM_Loading --> GM_Error : GroupMessagesLoadFailed
  GM_Error --> GM_Loading : LoadGroupMessages

  GM_Ready --> GM_Sending : BroadcastRequested
  GM_Sending --> GM_Ready : BroadcastAcknowledged
  GM_Sending --> GM_Error : BroadcastFailed

  GM_Ready --> GM_Ready : OwnerRealtimeReceived
}

state c_nav {
  GroupHomeVisible
  GroupChatOpen
  [*] --> GroupHomeVisible
  GroupHomeVisible --> GroupChatOpen : OpenGroupChat
  GroupChatOpen --> GroupHomeVisible : BackToGroupHome
}

note right of GM_Sending
  No optimistic bubble —
  serializes broadcast
end note

@enduml
