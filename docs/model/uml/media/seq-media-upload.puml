@startuml seq-media-upload
' Context: media
' Commands: SendImage, SendVideo, UploadMedia (retry)
' SDD: PROM-CHAT-MEDIA-001–007
' Revision: 2026-07-19

title seq-media-upload — foto / video con preview optimistic

actor Utente
participant "UI" as UI
participant "MessagingCoordinator" as Coord
participant "OutboundMediaCache" as Cache
participant "OutboundQueue" as Q
participant "MessageMediaService" as MMS
participant "MessageService" as MS

== Image ==

Utente -> UI : seleziona immagine
UI -> Coord : SendImage
Coord -> Cache : MediaCached
Coord --> UI : optimistic preview (pending)

Coord -> Q : MediaPersisted + enqueue
opt HEIC / normalize
  Coord --> Coord : ImageNormalized
end
Coord -> MMS : UploadMedia
MMS --> Coord : MediaUploaded
Coord -> MS : send image to profile
MS --> Coord : SendAcknowledged
Coord -> Q : dequeue

== Video ==

Utente -> UI : seleziona video
UI -> Coord : SendVideo
Coord --> UI : optimistic preview
Coord -> Cache : MediaCached
Coord -> Q : MediaPersisted + enqueue
Coord -> MMS : UploadMedia
MMS --> Coord : MediaUploaded
Coord -> MS : send video to profile
MS --> Coord : SendAcknowledged
Coord -> Q : dequeue

alt failure
  Coord --> UI : MediaUploadFailed
  Coord -> Q : update failed item
end

@enduml
