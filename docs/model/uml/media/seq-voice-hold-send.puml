@startuml seq-voice-hold-send
' Context: media
' Commands: RecordVoiceStart, RecordVoiceStop, SendVoice
' SDD: PROM-CHAT-MEDIA (voice), PROM-OUTBOUND-SEND
' Revision: 2026-07-19

title seq-voice-hold-send — registrazione hold-to-send

actor Utente
participant "UI" as UI
participant "VoiceRecordingService" as VRS
participant "MessagingCoordinator" as Coord
participant "OutboundQueue" as Q
participant "MessageMediaService" as MMS
participant "MessageService" as MS

Utente -> UI : long-press mic
UI -> VRS : RecordVoiceStart
UI --> UI : VoiceRecordingStarted

alt swipe up (lock)
  UI --> UI : VoiceRecordingLocked
  Utente -> UI : stop
  UI -> VRS : RecordVoiceStop
  UI --> UI : VoicePreviewReady
  Utente -> UI : conferma invio
else release (≥ min 1s)
  Utente -> UI : release
  UI -> VRS : RecordVoiceStop
  VRS --> UI : bytes, duration
else release (< 1s)
  UI -> VRS : RecordVoiceCancel
  UI --> UI : VoiceRecordingCancelled
end

UI -> Coord : SendVoice
Coord -> Q : persist media
Coord --> UI : optimistic voice bubble
Coord -> MMS : UploadMedia
MMS --> Coord : MediaUploaded
Coord -> MS : send voice to profile
MS --> Coord : SendAcknowledged
Coord -> Q : dequeue

@enduml
