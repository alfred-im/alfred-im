@startuml seq-close-conversation
' Command: CloseConversation
' Revision: 2026-07-19

title seq-close-conversation — back mobile / chiudi chat

actor Utente
participant "UI" as UI
participant "NavigationMachine" as Nav
participant "MultiAccountMachine" as MAM

Utente -> UI : back / chiudi chat
UI -> Nav : CloseConversation\n(o BackToGroupHome)

alt account utente
  Nav -> MAM : update view state (inbox visible)
  Nav --> UI : NavigationIdle
else account gruppo
  Nav -> MAM : update view state (group home)
  Nav --> UI : GroupShellEntered
end

@enduml
