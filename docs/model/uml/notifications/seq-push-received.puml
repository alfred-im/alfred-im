@startuml seq-push-received
' Context: notifications
' Profile: client
' Command: HandlePushPayload
' SDD: PROM-PUSH-NOTIFY-022, SURF-NOTIFICATIONS-005–008
' Revision: 2026-07-19

title seq-push-received — delivery server → notifica visibile o soppressa

participant "DeliveryWorker" as Del
participant "PushPlatform" as PP
participant "ServiceWorker" as SW
participant "NotificationsMachine" as NM
participant "UI" as UI

Del -> PP : PushNotifyEnqueued
PP -> SW : push event

UI -> NM : UpdateSuppressionState
NM -> SW : SuppressionStateApplied

SW -> SW : HandlePushPayload
SW -> SW : shouldSuppress?

alt soppresso (chat attiva stessa coppia)
  SW -> SW : PushNotificationSuppressed\n(nessuna UI)
else mostra
  SW -> SW : NotificationShown
end

@enduml
