@startuml profile-edit-state
' Context: profile
' SDD: PROM-PROFILE-IDENTITY
' Revision: 2026-07-19

title Profile — ProfileMachine (own profile)

state Idle
state Saving
state UploadingAvatar

[*] --> Idle

Idle --> Saving : SaveProfile
Saving --> Idle : ProfileSaved
Saving --> Idle : ProfileSaveFailed

Idle --> UploadingAvatar : UploadAvatar
UploadingAvatar --> Saving : AvatarUploaded\n+ SaveProfile
UploadingAvatar --> Idle : AvatarUploadFailed

note right of Saving
  Policy: RefreshAuthProfile
  after ProfileSaved
end note

@enduml
