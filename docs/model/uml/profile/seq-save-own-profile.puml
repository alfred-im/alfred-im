@startuml seq-save-own-profile
' Context: profile
' SDD: PROM-PROFILE-IDENTITY-003
' Revision: 2026-07-19

title Profile — salvataggio profilo proprio

actor Utente
participant "UI" as UI
participant "ProfileMachine" as PM
participant "ProfileService" as Svc
participant "MultiAccountMachine" as MAM
participant "Supabase" as DB

Utente -> UI : Salva
UI -> PM : SaveProfile
PM -> Svc : updateProfile(userId, fields)
Svc -> DB : UPDATE profiles
DB --> Svc : row
Svc --> PM : ProfileSaved
PM --> UI : profilo aggiornato

PM -> MAM : RefreshAuthProfile
MAM --> UI : AuthProfileRefreshed

@enduml
