@startuml seq-add-allowed-profile
' Context: reception
' SDD: PROM-RECEPTION-FILTER, SYS-RECEPTION-004
' Revision: 2026-07-19

title Reception — aggiunta profilo consentito

actor Utente
participant "UI" as UI
participant "ReceptionMachine" as RM
participant "ReceptionService" as Svc
participant "Supabase" as DB

Utente -> UI : consente profilo
UI -> RM : AddAllowedProfile(profile)

alt self o duplicato
  RM --> UI : AddSkipped
else
  RM -> Svc : addAllowedProfile(owner, profile)
  Svc -> DB : INSERT reception_allowlist
  DB --> Svc : row
  Svc --> RM : ProfileAllowed

  RM -> RM : LoadAllowlist
  RM -> Svc : fetchAllowedPeople(owner)
  Svc -> DB : SELECT + join profiles
  DB --> Svc : rows
  Svc --> RM : AllowlistLoaded
  RM --> UI : lista aggiornata
end

@enduml
